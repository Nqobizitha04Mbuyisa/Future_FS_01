# Copy this file to .env and fill in your values.
# DO NOT commit .env — it's in .gitignore.

# MongoDB connection string (from MongoDB Atlas → Connect → Drivers)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name (Atlas creates it on first write — pick anything)
DB_NAME=portfolio_db

# Comma-separated list of origins allowed to call this API.
# In production, set to your frontend URL(s) only.
# Example: ALLOWED_ORIGINS=https://your-site.vercel.app,https://yourdomain.com
# Leave as * for local development only.
ALLOWED_ORIGINS=*
