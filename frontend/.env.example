# Copy this file to .env and fill in your values.
# DO NOT commit .env — it's in .gitignore.

# Backend API base URL (no trailing slash, no /api suffix)
# Local dev: http://localhost:8001
# Production: your Render/Railway URL, e.g. https://portfolio-api.onrender.com
REACT_APP_BACKEND_URL=http://localhost:8001

# EmailJS credentials (from emailjs.com dashboard)
# These are PUBLIC by design — safe to expose in browser bundle.
# Lock them down by domain in EmailJS → Account → Security.
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=

# Optional CRA dev-server tweaks (you can leave these alone)
WDS_SOCKET_PORT=443
